{
  "name": "Notification",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "Email do usu\u00e1rio que receber\u00e1 a notifica\u00e7\u00e3o"
    },
    "title": {
      "type": "string",
      "description": "T\u00edtulo da notifica\u00e7\u00e3o"
    },
    "message": {
      "type": "string",
      "description": "Mensagem da notifica\u00e7\u00e3o"
    },
    "type": {
      "type": "string",
      "enum": [
        "candidatura_aprovada",
        "candidatura_rejeitada",
        "submissao_aprovada",
        "submissao_rejeitada",
        "tarefa_expirando",
        "info"
      ],
      "description": "Tipo da notifica\u00e7\u00e3o"
    },
    "is_read": {
      "type": "boolean",
      "default": false,
      "description": "Se a notifica\u00e7\u00e3o foi lida"
    },
    "related_task_id": {
      "type": "string",
      "description": "ID da tarefa relacionada (opcional)"
    },
    "related_task_title": {
      "type": "string",
      "description": "T\u00edtulo da tarefa relacionada (opcional)"
    }
  },
  "required": [
    "user_email",
    "title",
    "message",
    "type"
  ]
}