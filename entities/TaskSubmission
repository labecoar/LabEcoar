{
  "name": "TaskSubmission",
  "type": "object",
  "properties": {
    "task_id": {
      "type": "string",
      "description": "ID da tarefa"
    },
    "task_title": {
      "type": "string",
      "description": "T\u00edtulo da tarefa"
    },
    "user_email": {
      "type": "string",
      "description": "Email do Ecoante"
    },
    "user_name": {
      "type": "string",
      "description": "Nome do Ecoante"
    },
    "proof_url": {
      "type": "string",
      "description": "URL da prova (link do post, v\u00eddeo, etc)"
    },
    "proof_file_url": {
      "type": "string",
      "description": "URL do arquivo enviado (screenshot, v\u00eddeo)"
    },
    "insights_file_url": {
      "type": "string",
      "description": "URL do arquivo de m\u00e9tricas/insights"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o adicional do Ecoante"
    },
    "status": {
      "type": "string",
      "enum": [
        "pendente",
        "aprovada",
        "rejeitada"
      ],
      "default": "pendente",
      "description": "Status da submiss\u00e3o"
    },
    "rejection_reason": {
      "type": "string",
      "description": "Motivo da rejei\u00e7\u00e3o (se aplic\u00e1vel)"
    },
    "points_earned": {
      "type": "number",
      "description": "Pontos ganhos"
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time",
      "description": "Data de submiss\u00e3o"
    },
    "validated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Data de valida\u00e7\u00e3o"
    },
    "quarter": {
      "type": "string",
      "description": "Trimestre da submiss\u00e3o (ex: Q1-2025)"
    }
  },
  "required": [
    "task_id",
    "task_title",
    "user_email",
    "user_name",
    "status"
  ]
}